{
	"name": "review-gym",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.8",
		"oxlint": "^1.71.0",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router-dom": "^7.18.0"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
